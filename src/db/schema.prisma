generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum Plan {
  smb
  agency
  enterprise
}

enum UserRole {
  admin
  account_manager
  designer
  client
}

enum ClientStatus {
  active
  paused
  archived
}

enum RunStatus {
  queued
  running
  complete
  failed
}

enum RelayStep {
  onboarding_gate
  copy
  in_design
  designs_completed
  am_review_design
  design_revisions
  am_qa_pre_client
  sent_to_client
  client_decision
  ready_to_schedule
  implementing_revisions
  revisions_complete
  final_qa_schedule
  completed
  client_review
  scheduling
}

enum RelayRole {
  admin
  am
  designer
  client
}

enum RelayEventType {
  pass_forward
  send_back
  revision_dispatched
  revision_completed
  force_step
}

enum ActivityKind {
  comment

  client_created
  client_profile_edited
  client_archived
  client_imported

  client_am_assigned
  client_am_unassigned
  client_designer_assigned
  client_designer_unassigned

  run_created
  run_queued
  run_started
  run_brief_ready
  run_facts_ready
  run_copy_ready
  run_completed
  run_failed
  run_deleted
  run_due_date_changed

  posts_created
  post_edited
  post_status_changed

  member_invited
  member_joined
  member_role_changed
  member_removed

  batch_created
  batch_completed
  batch_force_stepped
  batch_passed
  batch_sent_back
  batch_revision_dispatched
  batch_revision_completed
  batch_step_advanced

  post_thread_opened
  post_thread_resolved
  post_caption_ai_fixed
  magic_link_created
  magic_link_visited

  review_session_started
  review_session_submitted
  review_caption_edit_accepted
  review_item_addressed
  review_item_unaddressed
  review_round_started
  preview_review_submitted
  client_review_decided
  revision_images_requested
}

enum ReviewSessionStatus {
  in_progress
  submitted
  superseded
}

enum ReviewDecision {
  not_reviewed
  approved
  changes_requested
  caption_edited
}

enum ThreadStatus {
  open
  resolved
}

/// Severity for in app "Report a bug" submissions. `high` triggers an
/// immediate admin email at submit time; all severities roll up in the
/// weekly digest. Phase 5 item 27.
enum FeedbackSeverity {
  low
  medium
  high
}

model Organization {
  id                   String   @id @default(cuid())
  name                 String
  plan                 Plan     @default(smb)
  clerkOrgId           String   @unique
  stripeCustomerId     String?
  stripeSubscriptionId String?
  runCredits           Int      @default(0)
  reviewWindowDays     Int      @default(7)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  users               User[]
  clients             Client[]
  roleDefaults        RoleDefault[]
  permissionAuditLogs PermissionAuditLog[]
  memberships         Membership[]
  trashAuditLogs      TrashAuditLog[]

  @@map("organizations")
}

model User {
  id                   String    @id @default(cuid())
  clerkUserId          String    @unique
  organizationId       String
  role                 UserRole  @default(admin)
  email                String
  name                 String
  avatarUrl            String?
  linkedClientId       String?
  permissionOverrides  Json?
  platformOwner        Boolean   @default(false)
  deactivatedAt        DateTime?
  createdAt            DateTime  @default(now())
  /// First time guided product tour persistence. Null = tour has not
  /// been dismissed yet, so the in app TourProvider auto fires (and
  /// the (app) layout redirects to /welcome on first sign in when
  /// launchPadDismissedAt is also null). Set when the user finishes
  /// step 3, ESC dismisses any step, or the Skip button is tapped.
  /// Phase 4 item 25.
  onboardingTourSeenAt DateTime?
  /// Set when the user dismisses /welcome ("Skip, I'll explore" link
  /// or top right X). Combined with onboardingTourSeenAt to decide
  /// whether the (app) layout should redirect a first time user to
  /// /welcome. Reset together by the Settings "Restart guided tour"
  /// control. Phase 4 item 25.
  launchPadDismissedAt DateTime?

  organization      Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedClients   Client[]             @relation("AssignedAM")
  designedClients   Client[]             @relation("AssignedDesigner")
  linkedClient      Client?              @relation("LinkedClient", fields: [linkedClientId], references: [id])
  triggeredRuns     ContentRun[]         @relation("TriggeredBy")
  auditLogsAsActor  PermissionAuditLog[] @relation("AuditActor")
  auditLogsAsTarget PermissionAuditLog[] @relation("AuditTarget")
  memberships       Membership[]
  heldBatches       Batch[]              @relation("BatchHolder")
  firedActivity     ActivityEvent[]      @relation("ActivityActor")
  mentions          Mention[]
  postVersions      PostVersion[]        @relation("PostVersionAuthor")
  threadsResolved   PostThread[]         @relation("ThreadResolver")
  threadsAuthored   PostThread[]         @relation("ThreadAuthor")
  commentsAuthored  PostComment[]        @relation("CommentAuthor")
  magicLinksCreated MagicLink[]          @relation("MagicLinkCreator")
  feedback          Feedback[]           @relation("FeedbackSubmitter")

  @@index([organizationId])
  @@index([linkedClientId])
  @@map("users")
}

model Client {
  id                  String       @id @default(cuid())
  organizationId      String
  assignedAmId        String?
  assignedDesignerId  String?
  name                String
  businessSummary     String?      @db.Text
  brandVoice          String?      @db.Text
  industry            String?
  location            String?
  phone               String?
  mainCta             String?
  focus1              String?
  focus2              String?
  focus3              String?
  dos                 String?      @db.Text
  donts               String?      @db.Text
  postingDays         String       @default("Mon,Wed,Fri")
  postLength          String?
  urls                String[]
  targetAudience      String?      @db.Text
  holidayHandling     String       @default("Major-US")
  excludedDates       String[]
  assetsFolderUrl     String?
  canvaUrl            String?
  autoCrawl           String       @default("always")
  crawledData         String?      @db.Text
  crawledDataAt       DateTime?
  clientReviewEnabled Boolean      @default(false)
  clientReviewEmail   String?
  status              ClientStatus @default(active)
  createdAt           DateTime     @default(now())
  deletedAt           DateTime?
  deletedBy           String?

  organization          Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedAm            User?           @relation("AssignedAM", fields: [assignedAmId], references: [id])
  assignedDesigner      User?           @relation("AssignedDesigner", fields: [assignedDesignerId], references: [id])
  linkedClientUsers     User[]          @relation("LinkedClient")
  contentRuns           ContentRun[]
  posts                 Post[]
  batches               Batch[]
  activityEvents        ActivityEvent[]
  onboardingCompletedAt DateTime?

  @@index([organizationId])
  @@index([assignedAmId])
  @@index([assignedDesignerId])
  @@index([deletedAt])
  @@map("clients")
}

model ContentRun {
  id               String    @id @default(cuid())
  clientId         String
  triggeredById    String
  /// Format: YYYY-MM (e.g. "2026-05"). Always store in this format — queries sort and filter by this field.
  targetMonth      String
  status           RunStatus @default(queued)
  triggerJobId     String?
  brief            String?   @db.Text
  supportingFacts  String?   @db.Text
  crawledContent   String?   @db.Text
  postingDates     String[]
  openaiCostUsd    Decimal?  @db.Decimal(10, 4)
  anthropicCostUsd Decimal?  @db.Decimal(10, 4)
  /// Crawler cost (currently Firecrawl). Renamed from apifyCostUsd
  /// after migrating off Apify; the value is the same dollar cost.
  crawlerCostUsd   Decimal?  @db.Decimal(10, 4)
  totalCostUsd     Decimal?  @db.Decimal(10, 4)
  creditsConsumed  Int?
  tokenUsage       Json?
  errorMessage     String?
  startedAt        DateTime?
  completedAt      DateTime?
  /// When true, pipeline completion auto-attaches posts (matching batch
  /// if exists, else auto-creates one) instead of waiting for the user
  /// to pick from the choice modal. Set when the user dismisses the
  /// generation dialog to "run in background".
  autoFinalize     Boolean   @default(false)
  acknowledgedAt   DateTime?
  /// When set, pipeline completion replaces this batch's posts with the
  /// run's posts in an atomic swap. Null means "create a new batch" on
  /// completion (today's auto-new path). Set by the pre-flight Replace
  /// flow in GenerateContentDialog. See projects/relay-app/2026-05-12-pre-flight-replace-design.md.
  targetBatchId    String?
  createdAt        DateTime  @default(now())
  deletedAt        DateTime?
  deletedBy        String?

  client         Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  triggeredBy    User            @relation("TriggeredBy", fields: [triggeredById], references: [id])
  targetBatch    Batch?          @relation("ContentRunTargetBatch", fields: [targetBatchId], references: [id], onDelete: SetNull)
  posts          Post[]
  activityEvents ActivityEvent[]

  @@index([clientId])
  @@index([deletedAt])
  @@index([targetBatchId])
  @@map("content_runs")
}

model Post {
  id            String    @id @default(cuid())
  contentRunId  String
  clientId      String
  batchId       String?
  postDate      DateTime
  caption       String    @db.Text
  preQaCaption  String?   @db.Text
  hashtags      String[]
  graphicHook   String?
  designerNotes String?
  mediaUrls     String[]
  scheduledAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  deletedBy     String?

  contentRun     ContentRun      @relation(fields: [contentRunId], references: [id], onDelete: Cascade)
  client         Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  batch          Batch?          @relation(fields: [batchId], references: [id], onDelete: SetNull)
  activityEvents ActivityEvent[]
  versions       PostVersion[]
  threads        PostThread[]
  reviewItems    ReviewItem[]

  /// Prevents Trigger.dev retries (or any future code path) from creating
  /// duplicate posts for the same (contentRunId, postDate). Belt-and-
  /// suspenders alongside maxAttempts: 1 in generateContent.ts.
  @@unique([contentRunId, postDate])
  @@index([contentRunId])
  @@index([clientId])
  @@index([batchId])
  @@index([deletedAt])
  @@map("posts")
}

/// Snapshot of a Post body taken on every save (cap 50 per post via the
/// PostVersion service). Powers diff and restore. Spec § Future Features § 2.
model PostVersion {
  id              String   @id @default(cuid())
  postId          String
  authorId        String?
  caption         String   @db.Text
  hashtags        String[]
  graphicHook     String?
  designerNotes   String?
  /// 'am' | 'reviewer' | null. Null preserves the meaning of pre-v2 rows.
  editAuthorRole  String?
  /// 'manual' | 'ai_fix' | 'review_session' | null.
  editOrigin      String?
  /// Links to the prior PostVersion this row supersedes. Null for the first
  /// version of a post.
  parentVersionId String?
  createdAt       DateTime @default(now())

  post                      Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  author                    User?         @relation("PostVersionAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  parentVersion             PostVersion?  @relation("PostVersionParent", fields: [parentVersionId], references: [id], onDelete: SetNull)
  childVersions             PostVersion[] @relation("PostVersionParent")
  acceptedFromReviewItems   ReviewItem[]  @relation("ReviewItemAcceptedVersion")
  lastReviewedByReviewItems ReviewItem[]  @relation("ReviewItemLastReviewedVersion")

  @@index([postId, createdAt])
  @@index([parentVersionId])
  @@map("post_versions")
}

model RoleDefault {
  id             String   @id @default(cuid())
  organizationId String
  role           UserRole
  permissionKey  String
  allow          Boolean
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, role, permissionKey])
  @@index([organizationId])
  @@map("role_defaults")
}

model PermissionAuditLog {
  id                   String    @id @default(cuid())
  organizationId       String
  actorUserId          String
  targetUserId         String?
  targetRole           UserRole?
  targetMembershipId   String?
  usedPlatformOverride Boolean   @default(false)
  permissionKey        String
  fromValue            Boolean?
  toValue              Boolean?
  createdAt            DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor        User         @relation("AuditActor", fields: [actorUserId], references: [id])
  target       User?        @relation("AuditTarget", fields: [targetUserId], references: [id])

  @@index([organizationId])
  @@index([targetUserId])
  @@map("permission_audit_logs")
}

model Membership {
  id                  String   @id @default(cuid())
  userId              String
  organizationId      String
  role                UserRole
  permissionOverrides Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
  @@map("memberships")
}

model Batch {
  id                  String    @id @default(cuid())
  clientId            String
  label               String
  currentStep         RelayStep
  currentSubState     String?
  currentHolder       String
  currentRole         RelayRole
  scheduledAt         DateTime?
  clientReviewEnabled   Boolean   @default(false)
  autoAdvanceOnTimeout  Boolean   @default(true)
  clientReviewStartedAt DateTime?
  createdAt             DateTime  @default(now())
  completedAt           DateTime?
  deletedAt             DateTime?
  deletedBy             String?

  client                Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  holder                User            @relation("BatchHolder", fields: [currentHolder], references: [id])
  posts                 Post[]
  checklists            ChecklistItem[]
  relayEvents           RelayEvent[]
  targetedByContentRuns ContentRun[]    @relation("ContentRunTargetBatch")
  magicLinks            MagicLink[]

  @@index([clientId, currentStep])
  @@index([currentHolder, currentStep])
  @@index([deletedAt])
  @@map("batches")
}

model RelayEvent {
  id        String         @id @default(cuid())
  batchId   String
  type      RelayEventType
  fromStep  RelayStep
  toStep    RelayStep
  fromUser  String
  toUser    String
  reason    String?        @db.Text
  payload   Json?
  createdAt DateTime       @default(now())

  batch Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId, createdAt])
  @@map("relay_events")
}

model ChecklistItem {
  id        String    @id @default(cuid())
  batchId   String
  step      RelayStep
  label     String
  required  Boolean   @default(true)
  checked   Boolean   @default(false)
  checkedBy String?
  checkedAt DateTime?

  batch Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId, step])
  @@map("checklist_items")
}

model ActivityEvent {
  id         String          @id @default(cuid())
  clientId   String
  runId      String?
  postId     String?
  actorId    String?
  kind       ActivityKind
  visibility EventVisibility @default(internal)
  payload    Json
  createdAt  DateTime        @default(now())

  client   Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  run      ContentRun? @relation(fields: [runId], references: [id], onDelete: Cascade)
  post     Post?       @relation(fields: [postId], references: [id], onDelete: Cascade)
  actor    User?       @relation("ActivityActor", fields: [actorId], references: [id], onDelete: SetNull)
  mentions Mention[]

  @@index([clientId, createdAt(sort: Desc)])
  @@index([clientId, visibility, createdAt(sort: Desc)])
  @@index([runId])
  @@index([postId])
  @@index([actorId])
  @@map("activity_events")
}

enum EventVisibility {
  /// Visible to everyone with access to the client, including client-role users.
  /// Use for: comments, run state changes the client cares about, client_decision events.
  public
  /// Visible to agency users (Admin / AM / Designer), hidden from client-role users.
  /// Default. Use for: profile field edits, internal handoffs, AM/Designer baton passes,
  /// assignment changes.
  internal
  /// Visible to Admin role only. Use for: permission overrides, member role changes,
  /// archival actions, sensitive audit entries.
  admin_only
}

model Mention {
  id              String    @id @default(cuid())
  activityEventId String
  mentionedUserId String
  readAt          DateTime?
  createdAt       DateTime  @default(now())

  event ActivityEvent @relation(fields: [activityEventId], references: [id], onDelete: Cascade)
  user  User          @relation(fields: [mentionedUserId], references: [id], onDelete: Cascade)

  @@unique([activityEventId, mentionedUserId])
  @@index([mentionedUserId, readAt])
  @@map("mentions")
}

model TrashAuditLog {
  id             String   @id @default(cuid())
  organizationId String
  actorUserId    String
  action         String // 'archive' | 'restore' | 'purge'
  entityType     String // 'client' | 'batch' | 'contentRun' | 'post'
  entityId       String
  parentContext  Json     @default("{}")
  cascadeCount   Int
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([entityId])
  @@index([action])
  @@index([createdAt])
  @@map("trash_audit_logs")
}

model PostThread {
  id     String       @id @default(cuid())
  postId String
  status ThreadStatus @default(open)

  // Pin location. Mutually exclusive: either both image coords set, OR both
  // caption offsets set, OR all four null (post-level thread).
  imageX      Float? // 0..100 percent of image width
  imageY      Float? // 0..100 percent of image height
  captionFrom Int? // char offset (inclusive) into Post.caption
  captionTo   Int? // char offset (exclusive) into Post.caption

  resolvedAt     DateTime?
  resolvedBy     String?
  resolvedReason String?

  // Dual-attribution: createdBy is a Clerk user OR reviewerToken is a magic link visitor.
  createdAt     DateTime @default(now())
  createdBy     String?
  reviewerToken String?

  post     Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  resolver User?         @relation("ThreadResolver", fields: [resolvedBy], references: [id], onDelete: SetNull)
  author   User?         @relation("ThreadAuthor", fields: [createdBy], references: [id], onDelete: SetNull)
  comments PostComment[]

  @@index([postId, status])
  @@index([reviewerToken])
  @@map("post_threads")
}

model PostComment {
  id       String @id @default(cuid())
  threadId String
  body     String @db.Text

  // Same dual-attribution shape as PostThread.
  authorId      String?
  reviewerToken String?
  reviewerName  String? // snapshot at comment time (in case the reviewer renames later)

  imageUrl    String?
  imageWidth  Int?
  imageHeight Int?

  createdAt DateTime @default(now())

  thread PostThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author User?      @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([threadId, createdAt])
  @@map("post_comments")
}

model MagicLink {
  id                   String    @id @default(cuid())
  batchId              String
  tokenHash            String    @unique // sha256 of the signed token, for revocation lookup
  defaultReviewerName  String
  defaultReviewerEmail String
  expiresAt            DateTime
  revokedAt            DateTime?
  createdBy            String
  createdAt            DateTime  @default(now())
  lastVisitedAt        DateTime?

  batch          Batch               @relation(fields: [batchId], references: [id], onDelete: Cascade)
  creator        User                @relation("MagicLinkCreator", fields: [createdBy], references: [id])
  reviewers      MagicLinkReviewer[]
  reviewSessions ReviewSession[]

  @@index([batchId])
  @@map("magic_links")
}

model MagicLinkReviewer {
  id          String @id @default(cuid())
  magicLinkId String

  name      String
  email     String?
  sessionId String  @unique // signed-cookie session ID; identifies same reviewer across visits

  firstSeen      DateTime  @default(now())
  lastSeen       DateTime  @default(now())
  /// Set when this reviewer has dismissed (or completed) the first visit
  /// tutorial modal on /review. Null means the modal has not been shown
  /// (or shown but POST to mark-seen failed). Per reviewer column because
  /// one magic link can have multiple reviewers.
  tutorialSeenAt DateTime?

  magicLink      MagicLink       @relation(fields: [magicLinkId], references: [id], onDelete: Cascade)
  reviewSessions ReviewSession[]

  @@index([magicLinkId])
  @@map("magic_link_reviewers")
}

/// One review pass by a magic-link reviewer over a batch's posts. Round 1 is
/// the initial review; round N+1 fires after the AM has addressed all items
/// from round N and called startNextRound. v2 of the client review flow.
model ReviewSession {
  id          String  @id @default(cuid())
  magicLinkId String
  /// Null until first-visit name confirm associates the session with a
  /// MagicLinkReviewer.
  reviewerId  String?

  status ReviewSessionStatus @default(in_progress)
  /// 1 for the first review, 2 for re-review after AM addressed changes, etc.
  round  Int                 @default(1)

  startedAt        DateTime  @default(now())
  submittedAt      DateTime?
  /// Snapshot of decision counts at submit time, used by the digest email.
  /// Shape: { approved: number, changesRequested: number, captionEdited: number, totalPosts: number }
  submittedSummary Json?

  /// Set by the sendReviewReminders cron when the 48h reminder email fires.
  /// Null = not yet reminded at this threshold. See
  /// projects/relay-app/2026-05-19-reviewer-reminder-cron-design.md.
  reminder48hSentAt DateTime?
  /// Set by the sendReviewReminders cron when the 96h reminder email fires.
  /// Null = not yet reminded at this threshold.
  reminder96hSentAt DateTime?

  magicLink MagicLink          @relation(fields: [magicLinkId], references: [id], onDelete: Cascade)
  reviewer  MagicLinkReviewer? @relation(fields: [reviewerId], references: [id], onDelete: SetNull)
  items     ReviewItem[]

  @@index([magicLinkId, round])
  @@index([reviewerId])
  @@map("review_sessions")
}

/// One reviewer decision (and optional comment / caption edit) for one post
/// inside a ReviewSession. Unique on (reviewSessionId, postId).
model ReviewItem {
  id              String @id @default(cuid())
  reviewSessionId String
  postId          String

  decision                ReviewDecision @default(not_reviewed)
  /// Free-text comment from the client. Optional, independent of decision.
  comment                 String?        @db.Text
  /// If decision = caption_edited, the suggested replacement caption lives
  /// here.
  suggestedCaption        String?        @db.Text
  /// PostVersion row created when AM accepts the suggested caption. Null
  /// until accepted.
  acceptedAsPostVersionId String?

  /// Round 2+: true when the AM edited this post between sessions, so the
  /// client sees the "Updated since your last review" banner.
  updatedSinceLastReview Boolean @default(false)
  /// When updatedSinceLastReview is true, this references the PostVersion the
  /// client last reviewed so we can show the diff if helpful.
  lastReviewedVersionId  String?

  reviewedAt DateTime?

  /// Set when an AM marks this item addressed (Mark addressed / Reject edit).
  /// Real state so "addressed" is reversible (un-address clears it). Accept
  /// path uses acceptedAsPostVersionId instead.
  addressedAt DateTime?
  addressedBy String?

  reviewSession ReviewSession @relation(fields: [reviewSessionId], references: [id], onDelete: Cascade)
  post          Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  acceptedAs    PostVersion?  @relation("ReviewItemAcceptedVersion", fields: [acceptedAsPostVersionId], references: [id], onDelete: SetNull)
  lastReviewed  PostVersion?  @relation("ReviewItemLastReviewedVersion", fields: [lastReviewedVersionId], references: [id], onDelete: SetNull)

  @@unique([reviewSessionId, postId])
  @@index([postId])
  @@index([decision])
  @@map("review_items")
}

/// In app "Report a bug" submission. One row per submit. The weekly
/// digest cron (sendFeedbackDigest, Mondays 13:00 UTC) collects every
/// row where sentInDigestAt is null and emails all admin users. When
/// severity = high, submitFeedbackAction also fires an immediate
/// urgent email at submit time and sets sentUrgentAt. Both timestamps
/// are independent tracking flags, not a "handled" marker; a single
/// high severity row ends up with both columns set.
///
/// Spec: projects/relay-app/2026-06-01-phase-5-item-27-feedback-channel-recommendation.md
model Feedback {
  id             String           @id @default(cuid())
  userId         String
  bodyText       String           @db.Text
  severity       FeedbackSeverity @default(medium)
  createdAt      DateTime         @default(now())
  /// Set by the sendFeedbackDigest cron when the row is included in a
  /// weekly digest send. Null = not yet digested.
  sentInDigestAt DateTime?
  /// Set by submitFeedbackAction when severity = high and the immediate
  /// admin email fires. Null for low/medium rows and for any high row
  /// where the urgent send failed (the digest still picks it up).
  sentUrgentAt   DateTime?

  user User @relation("FeedbackSubmitter", fields: [userId], references: [id], onDelete: Cascade)

  @@index([sentInDigestAt])
  @@index([userId])
  @@map("feedback")
}
