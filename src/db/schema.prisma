generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum Plan {
  smb
  agency
  enterprise
}

enum UserRole {
  admin
  account_manager
  designer
  client
}

enum ClientStatus {
  active
  paused
  archived
}

enum RunStatus {
  queued
  running
  complete
  failed
}

enum ApprovalStatus {
  draft
  am_review
  design_review
  client_review
  approved
  scheduled
}

enum ApprovalAction {
  approved
  rejected
  commented
  edited
}

enum ApprovalStage {
  am
  design
  client
}

enum RelayStep {
  onboarding_gate
  copy
  in_design
  designs_completed
  am_review_design
  design_revisions
  am_qa_pre_client
  sent_to_client
  client_decision
  ready_to_schedule
  implementing_revisions
  revisions_complete
  final_qa_schedule
}

enum RelayRole {
  admin
  am
  designer
  client
}

enum RelayEventType {
  pass_forward
  send_back
  revision_dispatched
  revision_completed
}

enum RevisionItemType {
  copy
  design
  am_inline
}

enum RevisionItemStatus {
  pending
  in_progress
  complete
}

enum ActivityKind {
  comment

  client_created
  client_profile_edited
  client_archived
  client_imported

  client_am_assigned
  client_am_unassigned
  client_designer_assigned
  client_designer_unassigned

  run_created
  run_queued
  run_started
  run_brief_ready
  run_facts_ready
  run_copy_ready
  run_completed
  run_failed
  run_deleted
  run_due_date_changed

  posts_created
  post_edited
  post_status_changed

  member_invited
  member_joined
  member_role_changed
  member_removed

  batch_created
  batch_passed
  batch_sent_back
  batch_revision_dispatched
  batch_revision_completed
  batch_step_advanced
}

model Organization {
  id                   String   @id @default(cuid())
  name                 String
  plan                 Plan     @default(smb)
  clerkOrgId           String   @unique
  stripeCustomerId     String?
  stripeSubscriptionId String?
  runCredits           Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  users               User[]
  clients             Client[]
  roleDefaults        RoleDefault[]
  permissionAuditLogs PermissionAuditLog[]
  memberships         Membership[]

  @@map("organizations")
}

model User {
  id                  String   @id @default(cuid())
  clerkUserId         String   @unique
  organizationId      String
  role                UserRole @default(admin)
  email               String
  name                String
  avatarUrl           String?
  linkedClientId      String?
  permissionOverrides Json?
  platformOwner       Boolean  @default(false)
  createdAt           DateTime @default(now())

  organization      Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedClients   Client[]             @relation("AssignedAM")
  designedClients   Client[]             @relation("AssignedDesigner")
  linkedClient      Client?              @relation("LinkedClient", fields: [linkedClientId], references: [id])
  triggeredRuns     ContentRun[]         @relation("TriggeredBy")
  approvalEvents    ApprovalEvent[]
  auditLogsAsActor  PermissionAuditLog[] @relation("AuditActor")
  auditLogsAsTarget PermissionAuditLog[] @relation("AuditTarget")
  memberships       Membership[]
  heldBatches       Batch[]              @relation("BatchHolder")
  firedActivity     ActivityEvent[]      @relation("ActivityActor")
  mentions          Mention[]

  @@index([organizationId])
  @@index([linkedClientId])
  @@map("users")
}

model Client {
  id                 String       @id @default(cuid())
  organizationId     String
  assignedAmId       String?
  assignedDesignerId String?
  name               String
  businessSummary    String?      @db.Text
  brandVoice         String?      @db.Text
  industry           String?
  location           String?
  phone              String?
  mainCta            String?
  focus1             String?
  focus2             String?
  focus3             String?
  dos                String?      @db.Text
  donts              String?      @db.Text
  postingDays        String       @default("Mon,Wed,Fri")
  postLength         String?
  urls               String[]
  targetAudience     String?      @db.Text
  holidayHandling    String       @default("Major-US")
  excludedDates      String[]
  assetsFolderUrl    String?
  autoCrawl          String       @default("always")
  crawledData        String?      @db.Text
  crawledDataAt      DateTime?
  status             ClientStatus @default(active)
  createdAt          DateTime     @default(now())

  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedAm        User?        @relation("AssignedAM", fields: [assignedAmId], references: [id])
  assignedDesigner  User?        @relation("AssignedDesigner", fields: [assignedDesignerId], references: [id])
  linkedClientUsers      User[]          @relation("LinkedClient")
  contentRuns            ContentRun[]
  posts                  Post[]
  batches                Batch[]
  activityEvents         ActivityEvent[]
  onboardingCompletedAt  DateTime?

  @@index([organizationId])
  @@index([assignedAmId])
  @@index([assignedDesignerId])
  @@map("clients")
}

model ContentRun {
  id               String    @id @default(cuid())
  clientId         String
  triggeredById    String
  /// Format: YYYY-MM (e.g. "2026-05"). Always store in this format — queries sort and filter by this field.
  targetMonth      String
  status           RunStatus @default(queued)
  triggerJobId     String?
  brief            String?   @db.Text
  supportingFacts  String?   @db.Text
  crawledContent   String?   @db.Text
  postingDates     String[]
  openaiCostUsd    Decimal?  @db.Decimal(10, 4)
  anthropicCostUsd Decimal?  @db.Decimal(10, 4)
  apifyCostUsd     Decimal?  @db.Decimal(10, 4)
  totalCostUsd     Decimal?  @db.Decimal(10, 4)
  creditsConsumed  Int?
  tokenUsage       Json?
  errorMessage     String?
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime  @default(now())

  client         Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  triggeredBy    User            @relation("TriggeredBy", fields: [triggeredById], references: [id])
  posts          Post[]
  activityEvents ActivityEvent[]

  @@index([clientId])
  @@map("content_runs")
}

model Post {
  id             String         @id @default(cuid())
  contentRunId   String
  clientId       String
  batchId        String?
  postDate       DateTime
  caption        String         @db.Text
  hashtags       String[]
  graphicHook    String?
  designerNotes  String?
  approvalStatus ApprovalStatus @default(draft)
  mediaUrls      String[]
  scheduledAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  contentRun     ContentRun      @relation(fields: [contentRunId], references: [id], onDelete: Cascade)
  client         Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  batch          Batch?          @relation(fields: [batchId], references: [id], onDelete: SetNull)
  approvalEvents ApprovalEvent[]
  activityEvents ActivityEvent[]

  @@index([contentRunId])
  @@index([clientId])
  @@index([batchId])
  @@index([approvalStatus])
  @@map("posts")
}

model ApprovalEvent {
  id        String         @id @default(cuid())
  postId    String
  userId    String?
  action    ApprovalAction
  stage     ApprovalStage
  comment   String?
  createdAt DateTime       @default(now())

  post Post  @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([postId])
  @@map("approval_events")
}

model RoleDefault {
  id             String   @id @default(cuid())
  organizationId String
  role           UserRole
  permissionKey  String
  allow          Boolean
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, role, permissionKey])
  @@index([organizationId])
  @@map("role_defaults")
}

model PermissionAuditLog {
  id                   String    @id @default(cuid())
  organizationId       String
  actorUserId          String
  targetUserId         String?
  targetRole           UserRole?
  targetMembershipId   String?
  usedPlatformOverride Boolean   @default(false)
  permissionKey        String
  fromValue            Boolean?
  toValue              Boolean?
  createdAt            DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor        User         @relation("AuditActor", fields: [actorUserId], references: [id])
  target       User?        @relation("AuditTarget", fields: [targetUserId], references: [id])

  @@index([organizationId])
  @@index([targetUserId])
  @@map("permission_audit_logs")
}

model Membership {
  id                  String   @id @default(cuid())
  userId              String
  organizationId      String
  role                UserRole
  permissionOverrides Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
  @@map("memberships")
}

model Batch {
  id              String    @id @default(cuid())
  clientId        String
  label           String
  currentStep     RelayStep
  currentSubState String?
  currentHolder   String
  currentRole     RelayRole
  scheduledAt     DateTime?
  createdAt       DateTime  @default(now())

  client       Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  holder       User            @relation("BatchHolder", fields: [currentHolder], references: [id])
  posts        Post[]
  checklists   ChecklistItem[]
  relayEvents  RelayEvent[]
  revisionPlan RevisionPlan?

  @@index([clientId, currentStep])
  @@index([currentHolder, currentStep])
  @@map("batches")
}

model RelayEvent {
  id        String         @id @default(cuid())
  batchId   String
  type      RelayEventType
  fromStep  RelayStep
  toStep    RelayStep
  fromUser  String
  toUser    String
  reason    String?        @db.Text
  payload   Json?
  createdAt DateTime       @default(now())

  batch Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId, createdAt])
  @@map("relay_events")
}

model ChecklistItem {
  id        String    @id @default(cuid())
  batchId   String
  step      RelayStep
  label     String
  required  Boolean   @default(true)
  checked   Boolean   @default(false)
  checkedBy String?
  checkedAt DateTime?

  batch Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId, step])
  @@map("checklist_items")
}

model RevisionPlan {
  id        String   @id @default(cuid())
  batchId   String   @unique
  createdAt DateTime @default(now())

  batch Batch          @relation(fields: [batchId], references: [id], onDelete: Cascade)
  items RevisionItem[]

  @@map("revision_plans")
}

model RevisionItem {
  id             String             @id @default(cuid())
  revisionPlanId String
  type           RevisionItemType
  description    String             @db.Text
  status         RevisionItemStatus @default(pending)
  assignedTo     String
  completedAt    DateTime?

  plan RevisionPlan @relation(fields: [revisionPlanId], references: [id], onDelete: Cascade)

  @@index([revisionPlanId, status])
  @@map("revision_items")
}

model ActivityEvent {
  id        String       @id @default(cuid())
  clientId  String
  runId     String?
  postId    String?
  actorId   String?
  kind      ActivityKind
  payload   Json
  createdAt DateTime     @default(now())

  client   Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  run      ContentRun? @relation(fields: [runId], references: [id], onDelete: Cascade)
  post     Post?       @relation(fields: [postId], references: [id], onDelete: Cascade)
  actor    User?       @relation("ActivityActor", fields: [actorId], references: [id], onDelete: SetNull)
  mentions Mention[]

  @@index([clientId, createdAt(sort: Desc)])
  @@index([runId])
  @@index([postId])
  @@index([actorId])
  @@map("activity_events")
}

model Mention {
  id              String    @id @default(cuid())
  activityEventId String
  mentionedUserId String
  readAt          DateTime?
  createdAt       DateTime  @default(now())

  event ActivityEvent @relation(fields: [activityEventId], references: [id], onDelete: Cascade)
  user  User          @relation(fields: [mentionedUserId], references: [id], onDelete: Cascade)

  @@unique([activityEventId, mentionedUserId])
  @@index([mentionedUserId, readAt])
  @@map("mentions")
}
