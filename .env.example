# Branch 2: Clerk Organizations (multi-tenant)
# Comma-separated allow-list of emails granted platformOwner=true. These users
# bypass per-org Membership requirements and have admin-equivalent access on
# every Organization in the DB. Audited via PermissionAuditLog.usedPlatformOverride.
RELAY_PLATFORM_OWNERS=""
# When "false", /sign-up redirects to /sign-in unless a Clerk invite ticket is
# present. Flip to "true" once billing is wired (Stage 1).
RELAY_ALLOW_PUBLIC_SIGNUP="false"
# When "true", a maintenance screen is shown for all routes. Used during the
# Phase 2/3 data migration cutover.
RELAY_MAINTENANCE_MODE="false"
