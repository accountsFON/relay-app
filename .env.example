# Database (Neon)
# DATABASE_URL points at the dev branch on local machines, the prod branch
# in Vercel + Trigger.dev. Pull from 1Password ("Relay App").
DATABASE_URL="postgresql://user:password@ep-dev-host.neon.tech/relay?sslmode=require"

# TEST_DATABASE_URL points at the test branch and is read only by
# scripts/run-integration-tests.ts and scripts/migrate-test-db.ts.
# Set on local machines only; unused in Vercel + Trigger.dev.
TEST_DATABASE_URL="postgresql://user:password@ep-test-host.neon.tech/relay?sslmode=require"

# Guardrail anchor. Set on local machines only. Destructive scripts
# (seed-demo, cleanup-leaked-test-orgs) refuse to run if the connection
# string's hostname matches this value, unless --i-know-this-is-prod
# is passed. Unset in Vercel + Trigger.dev (where the guard is a no-op).
PROD_DATABASE_HOSTNAME="ep-odd-math-a4uda3vs.us-east-1.aws.neon.tech"

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/onboarding"

# Trigger.dev (added in Plan 3)
TRIGGER_SECRET_KEY=""

# OpenAI (added in Plan 3)
OPENAI_API_KEY=""

# Anthropic (added in Plan 3)
ANTHROPIC_API_KEY=""

# Firecrawl (web crawling — replaced Apify in Plan 2)
FIRECRAWL_API_KEY=""

# Cloudflare R2 (added in Plan 4)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# Vercel Blob (post media, added in post preview + feedback system)
# Auto-injected by the Vercel Blob Marketplace integration in production.
# For local dev, run `vercel env pull` after enabling Blob on the project.
# When unset locally, src/lib/media.ts returns stub URLs so vitest can run
# without a live integration.
BLOB_READ_WRITE_TOKEN=""

# Stripe (added in Plan 6)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_STARTER_PRICE_ID=""
STRIPE_GROWTH_PRICE_ID=""
STRIPE_SCALE_PRICE_ID=""
STRIPE_OVERAGE_PRICE_ID=""

# Branch 2: Clerk Organizations (multi-tenant)
# Comma-separated allow-list of emails granted platformOwner=true. These users
# bypass per-org Membership requirements and have admin-equivalent access on
# every Organization in the DB. Audited via PermissionAuditLog.usedPlatformOverride.
RELAY_PLATFORM_OWNERS=""
# When "false", /sign-up redirects to /sign-in unless a Clerk invite ticket is
# present. Flip to "true" once billing is wired (Stage 1).
RELAY_ALLOW_PUBLIC_SIGNUP="false"
# When "true", a maintenance screen is shown for all routes. Used during the
# Phase 2/3 data migration cutover.
RELAY_MAINTENANCE_MODE="false"

# Magic link signing key for /review/[token] post preview links.
# 32+ random bytes base64-encoded. Generate with: openssl rand -base64 32
# Required at module load time — the magic-link lib throws if unset.
MAGIC_LINK_SECRET=""
